<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Domains</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
          rel="stylesheet">
</head>
<body>
    <div class="container">
        <% domains.forEach(d => { %>
            <div class="card" style="width: 18rem;">
                <div class="card-body">
                    <h5 class="card-title"><%= d.domain %> </h5>
                    <h6 class="card-subtitle mb-2 text-body-secondary"><%= new Date(d.created_at).toLocaleString() %></h6>
                    <p class="card-text"> </p>
                    <a href="/dashboard/<%= d.id %>" class="card-link">Domain Dashboard</a>
                </div>
            </div>
        <% }) %>
    </div>
    
    
</body>
</html>