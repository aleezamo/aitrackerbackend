<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> <%=title%> </title>
    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
  rel="stylesheet">
</head>
<body>
  <div class="container">
  <% if (duration=="1d") { %>
     <a href="/dashboard?duration=1d" class="link-primary">1 day</a>
  <% } else { %>
      <a href="/dashboard?duration=1d" class="link-secondary">1 day</a>
  <% }%>

  <% if (duration!="1m" && duration!="1d" && duration!="14d") { %>
     <a href="/dashboard?duration=7d" class="link-primary">7 days</a>
  <% } else { %>
      <a href="/dashboard?duration=7d" class="link-secondary">7 days</a>
  <% }%>

  <% if (duration=="14d") { %>
     <a href="/dashboard?duration=14d" class="link-primary">14 days</a>
  <% } else { %>
      <a href="/dashboard?duration=14d" class="link-secondary">14 days</a>
  <% }%>

  <% if (duration=="1m") { %>
     <a href="/dashboard?duration=1m" class="link-primary">1 month</a>
  <% } else { %>
      <a href="/dashboard?duration=1m" class="link-secondary">1 month</a>
  <% }%>


  <div class="container mt-4">
    <div class="row g-3">
      <%- include('partials/analyticstable', {
          title: 'AI Sources',
          headers: ['Source', 'Count'],
          rows: aiSources
        }) %>

      <%- include('partials/analyticstable', {
        title: 'Top Pages',
        headers: ['Page', 'Views'],
        rows: pageTitles
        }) %>

      <%- include('partials/analyticstable', {
        title: 'Path Names',
        headers: ['Path', 'Views'],
        rows: pathNames
        }) %>
      </div>
    </div>
  </div>


    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js">
    </script>
</body>
</html>