<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> <%=title%> </title>
    <link
  href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
  rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
</head>
<body>
  <div class="container">

    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/sites">Sites</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%=title%></li>
      </ol>
    </nav>


    <div>
      <h1>Dashboard</h1> 
      <h2><%=site_name.domain%></h2> 
    </div>

  <% if (duration=="1d") { %>
     <a href="/sites/<%=site_id%>/dashboard/?duration=1d" class="link-primary">1 day</a>
  <% } else { %>
      <a href="/sites/<%=site_id%>/dashboard/?duration=1d" class="link-secondary">1 day</a>
  <% }%>

  <% if (duration!="1m" && duration!="1d" && duration!="14d") { %>
     <a href="/sites/<%=site_id%>/dashboard/?duration=7d" class="link-primary">7 days</a>
  <% } else { %>
      <a href="/sites/<%=site_id%>/dashboard/?duration=7d" class="link-secondary">7 days</a>
  <% }%>

  <% if (duration=="14d") { %>
     <a href="/sites/<%=site_id%>/dashboard/?duration=14d" class="link-primary">14 days</a>
  <% } else { %>
      <a href="/sites/<%=site_id%>/dashboard/?duration=14d" class="link-secondary">14 days</a>
  <% }%>

  <% if (duration=="1m") { %>
     <a href="/sites/<%=site_id%>/dashboard/?duration=1m" class="link-primary">1 month</a>
  <% } else { %>
      <a href="/sites/<%=site_id%>/dashboard/?duration=1m" class="link-secondary">1 month</a>
  <% }%>


  <div class="container mt-4">
    <div style="position: relative; height:40vh; width:80vw">
        <canvas id="myChart"></canvas>
    </div>

    <div class="row g-3">
      <%- include('partials/analyticstable', {
          title: 'AI Sources',
          headers: ['Source', 'Count'],
          rows: aiSources
        }) %>

      <%- include('partials/analyticstable', {
        title: 'Top Pages',
        headers: ['Page', 'Views'],
        rows: pageTitles
        }) %>

      <%- include('partials/analyticstable', {
        title: 'Path Names',
        headers: ['Path', 'Views'],
        rows: pathNames
        }) %>
      </div>
    </div>
  </div>


    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js">
    </script>

    <script defer>
      const path = window.location.pathname;
      const match = path.match(/\/sites\/([0-9a-fA-F-]{36})\/dashboard/);
      const uuid = match?.[1];
      if (!uuid) {
        console.err("Invalid UUID")
      }

      fetch('http://localhost:8000/charts/' + uuid)
      .then(response => {
      // Check if the request was successful
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      return response.json(); // Parses the body content as JSON
      })
        .then(data => {
          const dates = data.map(item => 
              new Date(item.date).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric'
          }));
          const counts = data.map(item => item.event_count)
          console.log(dates);
          console.log(counts);

          chart.data.labels = dates;
          chart.data.datasets[0].data = counts;
          chart.update();
        }) // Handle the data
        .catch(error => console.error('Fetch error:', error)); // Handle network errors
    </script>

    <script>
  const ctx = document.getElementById('myChart');

    chart = new Chart(ctx, {
      type: 'bar', // Options: 'line', 'pie', 'doughnut', etc.
      data: {
        labels: [],
        datasets: [{
          label: '# of AI Referrals',
          data: [],
          backgroundColor: 'rgba(54, 162, 235, 0.2)', // Fill color (light blue)
          borderColor: 'rgba(123, 0, 0, 1)',       // Line color (solid blue)
          borderWidth: 2,
          borderWidth: 1
        }]
      },
      options: {
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      }
    });
  </script>
</body>
</html>